          "lookahead",
          "dogrula",
          "repair",
          "escalate"
        ],
        "envOptIn": "UKP_WEBHOOK",
        "receiverTodo": "POST /api/ingest/stage-events (HMAC-verify X-Ukp-Signature) — ollamas-lane"
      }
    },
