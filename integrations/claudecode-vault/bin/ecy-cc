#!/usr/bin/env python3
"""eCym Claude Code doc-Q&A köprüsü: soruyu ollamas brain recall'a atar,
claude-code notlarından özet + kaynak döndürür ($0 local)."""
import sys, json, urllib.request
q = " ".join(sys.argv[1:]).strip()
if not q:
    print("kullanım: ecy-cc \"<soru>\""); sys.exit(1)
try:
    payload = json.dumps({"query": q, "k": 4}).encode()
    req = urllib.request.Request("http://localhost:3000/api/brain/recall",
                                 data=payload, headers={"content-type": "application/json"})
    hits = json.load(urllib.request.urlopen(req, timeout=20)).get("hits", [])
except Exception as e:
    print(f"[ecy-cc] brain erişilemedi ({e}) — ollamas :3000 çalışıyor mu?"); sys.exit(2)
cc = [h for h in hits if str(h.get("id", "")).startswith("claude-code")]
if not cc:
    print(f"[ecy-cc] '{q}' için claude-code notu bulunamadı."); sys.exit(0)
print(f"🔎 Claude Code — \"{q}\"\n")
for h in cc[:3]:
    content = h.get("content", "")
    kaynak = ""
    for line in content.splitlines():
        if "🔗 Kaynak:" in line:
            kaynak = line.split("🔗 Kaynak:")[-1].strip().strip("*").strip(); break
    body = "\n".join(l for l in content.splitlines()
                     if l.strip() and not l.startswith(("#", ">", "---", "**Kategori", "**Hub", "**İlgili", "**🔗")))
    snippet = body[:420].rsplit(".", 1)[0] + "." if body else ""
    print(f"● {h['id'].replace('claude-code:','')}  (skor {round(h.get('score',0),2)})")
    if snippet: print(f"  {snippet}")
    if kaynak: print(f"  🔗 {kaynak}")
    print()
