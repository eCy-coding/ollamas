{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "ollamas-mcp": "dist/mcp-stdio.cjs"
  },
  "scripts": {
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild bin/mcp-stdio.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/mcp-stdio.cjs",
    "build:binary": "bash cli/build-binary.sh",
    "build:cli": "esbuild cli/index.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/cli/index.cjs",
    "build:client": "vite build",
    "build:sea": "bash cli/build-sea.sh",
    "clean": "rm -rf dist",
    "agent": "node scripts/agent-dispatch.mjs",
    "oracle:verify": "bash scripts/oracle-verify-gate.sh",
    "cli": "tsx cli/index.ts",
    "content:gen": "node scripts/content-pipeline.mjs",
    "doctor": "node bin/host-bridge/doctor.mjs",
    "monitor": "node scripts/system-monitor.mjs",
    "ops": "node scripts/ops.mjs",
    "ready": "node scripts/ready.mjs",
    "cover:gen": "node scripts/cover-gen.mjs",
    "conformance": "vitest run tests/conformance.e2e.test.ts",
    "conformance:http": "mcp-inspector --cli http://localhost:${PORT:-3000}/mcp --transport http --method tools/list",
    "conformance:stdio": "mcp-inspector --cli node dist/mcp-stdio.cjs --method tools/list",
    "dev": "tsx server.ts",
    "gemini:lane": "node scripts/gemini-lane.mjs",
    "harden": "make harden",
    "lint": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "mcp:stdio": "tsx bin/mcp-stdio.ts",
    "perf": "lhci autorun",
    "postbuild:cli": "chmod +x dist/cli/index.cjs",
    "size": "size-limit",
    "smoke": "vitest run tests/smoke-live.e2e.test.ts",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:web": "playwright test -c playwright.web.config.ts",
    "tokens": "style-dictionary build --config style-dictionary.config.js && style-dictionary build --config style-dictionary.light.config.js"
  },
  "dependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@google/genai": "^2.4.0",
    "@lingui/core": "^6.4.0",
    "@lingui/react": "^6.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "ajv": "^8.20.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "js-tiktoken": "^1.0.21",
    "lru-cache": "^11.5.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^25.1.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-error-boundary": "^6.1.2",
    "sqlite-vec": "^0.1.9",
    "stripe": "^22.2.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "vite": "^6.2.3",
    "web-vitals": "4.2.4",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "tmp": "^0.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@playwright/test": "^1.61.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "commander": "^13.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "postject": "^1.0.0-alpha.6",
    "size-limit": "^12.1.0",
    "style-dictionary": "^5.4.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
