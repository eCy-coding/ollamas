# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: The port the backend server binds to.
# Note: AI Studio only serves external traffic routed to port 3000.
PORT=3000

# OLLAMA_HOST: Endpoint hosting local offline models daemon on macOS workstation.
# Remote GPU backend (Windows PC over Tailscale/LAN) — see cli/REMOTE_GPU.md.
# Use the node path (npm start); the Docker path hardcodes host.docker.internal.
#   OLLAMA_HOST="http://<win-host>.<tailnet>.ts.net:11434"   # Tailscale MagicDNS
#   OLLAMA_HOST="http://192.168.x.y:11434"                   # LAN fallback
OLLAMA_HOST="http://localhost:11434"

# OLLAMA_NUM_CTX: Lock local context load bounds to prevent Metal GPU Out-Of-Memory.
OLLAMA_NUM_CTX=8192

# ─────────────────────────────────────────────────────────────────────────────
# MCP Gateway + tools-as-SaaS (see README "MCP Gateway + tools-as-SaaS")
# ─────────────────────────────────────────────────────────────────────────────

# HOST_TOOLS_DIR: Absolute HOST path to bin/host-bridge/tools. Bridge tools run on
# the host, so in Docker this must be the host repo path (the container path is
# wrong). In dev (tsx on host) it defaults to <cwd>/bin/host-bridge/tools.
# HOST_TOOLS_DIR="/Users/you/Desktop/ollamas/bin/host-bridge/tools"

# SAAS_ENFORCE: "1" requires a valid API key on /mcp (multi-tenant mode) and makes
# SAAS_ADMIN_TOKEN mandatory. Unset/"0" = single-user localhost (no auth).
SAAS_ENFORCE=0

# SAAS_ADMIN_TOKEN: Guards /api/saas/* + /api/billing/* (X-Admin-Token header).
# MANDATORY when SAAS_ENFORCE=1 (admin routes lock without it).
SAAS_ADMIN_TOKEN=""

# ── O0 modules (ODYSSEY foundation) — optional feature modules ──
# Each MODULE_<ID> toggles one module. DEFAULT OFF: only the literal "1" enables.
# ON  → routes mount under /api/modules/<id>/*, tools register, tab appears.
# OFF → routes 404, tools absent from tools/list, tab hidden (total blackout).
# All module routes inherit the localOwnerGuard (SAAS_ENFORCE=1 → 403).
MODULE_DEMO=0
# Reserved for later modules (enable when shipped):
# MODULE_NOTES=0     # O5 notes/tasks
# MODULE_CALENDAR=0  # O6 calendar
# MODULE_DOCS=0      # O3 documents
# MODULE_EMAIL=0     # O4 email (IMAP/SMTP triage — docs/odyssey/05-features/email-mcp.md)
# MODULE_SETTINGS=0  # O8 settings (2FA/TOTP + RBAC + tool-policy + sessions — docs/odyssey/07-security.md)

# ── O4 email (provider-agnostic IMAP/SMTP, only active when MODULE_EMAIL=1) ──
# No mailbox configured → the panel shows "not connected" (graceful, never a
# crash). Triage + AI summary/draft run on the $0 local model (qwen3:8b);
# nothing is sent to a cloud provider. SMTP is the ONE privileged action.
# EMAIL_IMAP_HOST="imap.example.com"
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_SECURE=1
# EMAIL_IMAP_USER="me@example.com"
# EMAIL_IMAP_PASSWORD=""          # app-password/OAuth2 preferred over a raw account password
# EMAIL_SMTP_HOST="smtp.example.com"
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=0             # STARTTLS on 587; set 1 for implicit TLS (465)
# EMAIL_SMTP_USER=""              # defaults to EMAIL_IMAP_USER when unset
# EMAIL_SMTP_PASSWORD=""          # defaults to EMAIL_IMAP_PASSWORD when unset

# SAAS_DB_PATH: SaaS store (node:sqlite). Defaults to ~/.llm-mission-control/saas.db.
# SAAS_DB_PATH="/abs/path/saas.db"

# MCP_EXPOSE_TIERS: CSV of tool tiers advertised/runnable on /mcp for the
# unauthenticated single-user path. Authenticated tenants use their plan's tiers.
MCP_EXPOSE_TIERS="safe,host,privileged"

# MCP_AUTO_APPLY: "0" makes /mcp write_file return a diff (halt) instead of applying.
MCP_AUTO_APPLY=1

# ALLOWED_ORIGINS: CSV of allowed Origin headers on /mcp (DNS-rebinding protection,
# MCP Transports spec). Empty = localhost/127.0.0.1 only. Requests with no Origin
# (server-to-server MCP clients) always pass.
ALLOWED_ORIGINS=""

# OAUTH_AUTH_SERVERS: CSV of OAuth authorization-server issuer URLs advertised in
# RFC 9728 /.well-known/oauth-protected-resource. Empty since ollamas issues opaque
# API keys (no OAuth server yet — see AGENTS.md backlog).
OAUTH_AUTH_SERVERS=""

# ── v1.0 GA (Faz 9) — all OPTIONAL; each feature falls back gracefully ──

# OAuth JWT validation (Faz 9B). When OAUTH_ISSUER is set, Bearer JWTs are verified
# via JWKS (jose) with issuer + audience checks; opaque olm_ keys still work.
# OAUTH_ISSUER="https://auth.example.com"
# OAUTH_AUDIENCE="https://mcp.example.com/mcp"
# OAUTH_JWKS_URI="https://auth.example.com/.well-known/jwks.json"

# API_KEY_MAX_TTL_DAYS: default expiry for newly issued API keys (0 = never).
API_KEY_MAX_TTL_DAYS=0

# REDIS_URL: when set, rate-limiting uses a shared atomic Redis token bucket
# (multi-instance correct). Unset = in-memory fallback (single instance).
# REDIS_URL="redis://localhost:6379"

# LOG_LEVEL: pino log level (trace|debug|info|warn|error). Default info.
LOG_LEVEL="info"

# ── v1.1 (Faz 10) ──

# HOST_BRIDGE_HMAC_SECRET: when set, server↔host-bridge requests are HMAC-SHA256
# signed (timestamp + nonce replay protection) instead of the plain token.
# Set the SAME value on the bridge process. Host tools still accept the token.
# HOST_BRIDGE_HMAC_SECRET="a-long-random-shared-secret"

# ── v1.2 (Faz 11) — tenant webhooks (all optional, sane defaults) ──
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_REQUEST_TIMEOUT_MS=15000
WEBHOOK_WORKER_INTERVAL_MS=30000

# Billing (optional). With no STRIPE_API_KEY, billing runs in DRY-RUN.
# STRIPE_API_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
BILLING_UNIT_PRICE=1

# RATE_LIMIT_MAX_BUCKETS: per-tenant rate-limit Map cap before idle eviction.
RATE_LIMIT_MAX_BUCKETS=10000

# ── v1.3 (Faz 12) — Postgres async store (multi-replica scale) ──
# Unset → node:sqlite at SAAS_DB_PATH (default, single-writer, one replica).
# Set → Postgres async store: horizontal scale, multi-replica-safe webhook
# worker (FOR UPDATE SKIP LOCKED). Same vitest suite passes on both dialects.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ollamas"
# DB_POOL_SIZE: pg connection pool max per replica (default 5).
DB_POOL_SIZE=5

# ── v1.4 (Faz 13) — production lifecycle ──
# SHUTDOWN_GRACE_MS: on SIGTERM/SIGINT, drain in-flight requests + stop the
# webhook worker, then close the DB pool, within this budget (default 10000ms).
SHUTDOWN_GRACE_MS=10000
# Schema migrations run automatically at boot (advisory-locked). To run them
# standalone (K8s pre-upgrade Job / Helm hook): `tsx server.ts --migrate-only`.

# ── v1.5 (Faz 14) — MCP logging ──
# MCP_LOG_LEVEL: base severity for server→client structured logs over /mcp
# (debug|info|notice|warning|error|critical|alert|emergency). Clients raise/lower
# it per connection via logging/setLevel. Default info.
MCP_LOG_LEVEL=info

# ── v1.6 (Faz 15) — MCP ecosystem interop + Dynamic Client Registration ──
# MCP_PUBLIC_URL: externally-reachable origin advertised in /.well-known/mcp.json,
# the RFC 8414/9728 metadata, and server.json's remote URL. Unset → derived from
# the incoming request (correct for localhost / direct exposure). Set this behind a
# reverse proxy or load balancer so discovery points at the public address.
# MCP_PUBLIC_URL="https://mcp.example.com"

# DCR_INITIAL_ACCESS_TOKEN: when set, POST /register (RFC 7591 Dynamic Client
# Registration) requires this token as `Authorization: Bearer <token>`. Unset =
# open registration (still rate-limited). Set it in shared/public deployments to
# stop registration spam.
# DCR_INITIAL_ACCESS_TOKEN=""

# ── Agent dispatch + readiness (scripts/agent-dispatch.mjs, ops.mjs, ready.mjs) ──
# OLLAMAS_URL: base URL the sub-agent dispatcher posts to (/api/agent/chat).
# Default http://127.0.0.1:8090. Point it at your dev server (http://127.0.0.1:3000)
# if you run the single combined server.
# OLLAMAS_URL="http://127.0.0.1:8090"
# OLLAMAS_TIMEOUT_MS: per-run sub-agent timeout (default 180000).
# OLLAMAS_TIMEOUT_MS=180000
# READY_MODEL: the model `npm run ready` ensures is pulled (default qwen3:8b).
# READY_MODEL="qwen3:8b"

# ── Optional tooling ──
# FIRECRAWL_API_KEY: web scrape/search for scripts/firecrawl.mjs + content-pipeline.mjs.
# Free tier works; on 402 the scripts fall back gracefully. Optional.
# FIRECRAWL_API_KEY=""

# ── MCP upstream supervisor (Faz 27) ──
# MCP_HEALTH_INTERVAL_MS: health-check interval (ms) for registered upstream MCP servers.
# MCP_HEALTH_INTERVAL_MS=30000
